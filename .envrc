# ============================================================
# Managed by the envrc script. Do not edit within this block.
# Any changes here will be overwritten on the next run.

# Automatically activate the Python virtual environment.
if [[ -f .venv/bin/activate ]]; then
    source .venv/bin/activate
fi

# API keys managed by pass.
export GROQ_API_KEY="$(pass api-keys/groq)"

# ============================================================
